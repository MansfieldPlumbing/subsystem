<?xml version="1.0" encoding="utf-8"?>
<!-- Widget card background. RemoteViews can't read theme CSS vars, so a static rounded surface stands
     in for the glass — the look gets theme-aware once the card rasterizer (layer 4) renders the real AC. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="#1C1C22" />
    <corners android:radius="20dp" />
    <stroke android:width="1dp" android:color="#33FFFFFF" />
</shape>
