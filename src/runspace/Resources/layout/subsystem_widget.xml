<?xml version="1.0" encoding="utf-8"?>
<!-- LAYER 1 widget layout: RemoteViews-safe views only (LinearLayout / ImageView / TextView). Static
     content; the registry value (layer 2) and the rasterized AC card (layer 4) replace it later. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">
    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:src="@mipmap/appicon"
        android:contentDescription="Subsystem" />
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subsystem"
            android:textColor="#F2F2F2"
            android:textSize="16sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to open"
            android:textColor="#9AA0AA"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
