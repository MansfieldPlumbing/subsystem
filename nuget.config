<?xml version="1.0" encoding="utf-8"?>
<!--
  Portable build-tools config. globalPackagesFolder is a RELATIVE path: NuGet resolves it against THIS
  file's folder (the repo root), so the package cache lives at <drive>\bin\nuget\packages — a sibling of
  the repo at the drive root (matching <drive>\subsystem + <drive>\bin + <drive>\dotnet). It moves with
  the drive (S:, T:, …) — never hardcoded, never reaching into C:\Users\…\.nuget. Found by walking up
  from any project under src\.
-->
<configuration>
  <config>
    <add key="globalPackagesFolder" value="..\bin\nuget\packages" />
  </config>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
